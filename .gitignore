gcloud/
gh/
github-copilot/
iterm2/
configstore/
git/credentials
stripe/
yarn/
**/*.env

# app-managed system skills (not user content)
codex/skills/.system/

# machine-specific state rewritten by the Codex app (absolute home paths)
codex/config.toml

# Hermes Agent per-machine state (config/SOUL/skills/mcp/cron ARE tracked; these are not)
hermes/**/auth.json
hermes/**/.env.EXAMPLE
hermes/**/memories/
hermes/**/sessions/
hermes/**/state.db*
hermes/**/logs/
hermes/**/workspace/
hermes/**/plans/
hermes/**/*_cache/
hermes/**/local/

# Hermes skills: agent-created skills ARE tracked; bundled skills (read via
# skills.external_dirs from the agent clone) + curator/hub/usage bookkeeping are not
hermes/**/.bundled_manifest
hermes/**/.usage.json
hermes/**/.usage.json.lock
hermes/**/.curator_state
hermes/**/.curator_suppressed
hermes/**/.curator_backups/
hermes/**/.archive/
hermes/**/.hub/
hermes/**/index-cache/
hermes/**/.restore-backups/

# Hermes cron: job definitions (cron/jobs.json) ARE tracked; runtime churn is not
hermes/**/cron/output/
hermes/**/cron/.tick.lock
hermes/**/cron/*.lock

# Hermes plugins: source IS tracked; Python bytecode (written into the symlinked
# plugins dir when Hermes loads a plugin) is not
hermes/**/__pycache__/
hermes/**/*.pyc

#!/bin/zsh -f
# secret — thin launcher so the `secret` Keychain CLI (a zsh function defined in
# zsh/functions/secret.zsh, loaded interactively by config.zsh) is also callable
# from non-interactive shells (opencode, scripts, `zsh -c`).
#
# This is NOT a secret-shim symlink: it injects nothing. It just loads the
# function and dispatches. Interactive shells keep using the function directly
# (a defined function outranks this PATH command), so behaviour is unchanged.
source "$HOME/.config/zsh/functions/secret.zsh" 2>/dev/null
if (( ! $+functions[secret] )); then
  print -ru2 -- "secret: could not load ~/.config/zsh/functions/secret.zsh"
  exit 1
fi
secret "$@"

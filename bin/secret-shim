#!/bin/zsh -f
# secret-shim — thin launcher that injects Keychain secrets, then execs the
# real command. Two modes, selected by the symlink name:
#
# -f (NO_RCS): never source ~/.zshenv etc. — the shim must see the caller's
# PATH exactly as-is, so the "real binary" lookup below stays predictable.
# PATH construction is zsh/env.zsh's job, done by the shell that runs us.
#
#   tool mode (default: opencode, claude, codex, copilot, ...)
#     secret env -p global      layer shared by every tool
#     secret env -p <command>   tool-specific layer (overrides global)
#
#   project mode (npm, pnpm, node, bun, yarn, npx, python, uv, docker, ...)
#     secret env                ambient project + repository scope, i.e. the
#                               secrets of the repository you are in
#     Injected only inside a git repository (never falls back to the
#     "global" project), and only for names that are not already defined
#     in a dotenv file — the application's own .env loader keeps priority.
#
# Effective precedence in both modes:
#   explicitly exported environment  >  .env files (project mode)  >  Keychain
#
# Dotenv detection (project mode) collects variable *names* (values are
# never read) from .env, .env.local and .env.{development,production,test}
# {,.local} — in every directory from $PWD up to the git toplevel, plus the
# subtree below $PWD (node_modules/.git pruned, depth-limited), so monorepo
# package files like apps/web/.env are respected when launching from the
# workspace root. Templates (.env.example, ...) are deliberately ignored.
#
# Usage: symlink a command name to this file:
#   ln -s secret-shim ~/.config/bin/<command>
# Nested launches are detected via _SECRET_SHIM_TOOL/_SECRET_SHIM_PROJ and
# skip re-injection. If the keychain cannot be unlocked, injection is
# skipped and the command starts anyway — the shim never blocks a launch.
#
# Test hooks: SECRET_SHIM_MODE forces the mode (tool|project),
# SECRET_SHIM_BASE replaces "global" as the tool-mode base project.

emulate zsh

name=${0:t}
self=${0:A}

mode=tool
case $name in
  npm|pnpm|node|bun|bunx|yarn|npx|python|python3|uv|docker|docker-compose) mode=project ;;
esac
[[ -n ${SECRET_SHIM_MODE:-} ]] && mode=$SECRET_SHIM_MODE
base=${SECRET_SHIM_BASE:-global}

# names exported before the shim ran — never overridden
typeset -A _had _skip
for _k in ${(k)parameters[(R)*export*]}; do _had[$_k]=1; done

_inject() {                    # args are passed to `secret env`
  local line n
  for line in ${(f)"$(secret env "$@" 2>/dev/null)"}; do
    [[ $line == export\ * ]] || continue
    n=${${line#export }%%=*}
    [[ -n ${_had[$n]:-} || -n ${_skip[$n]:-} ]] && continue
    eval "$line"
  done
}

_scan_dotenv() {               # $1 git toplevel; fills _skip with dotenv names
  local -a bases files args
  bases=(.env .env.local .env.development .env.development.local
         .env.production .env.production.local .env.test .env.test.local)
  local d=$PWD f
  while true; do               # ancestors: $PWD up to the toplevel
    for f in $bases; do [[ -f $d/$f ]] && files+=("$d/$f"); done
    [[ $d == "$1" || $d == / ]] && break
    d=${d:h}
  done
  for f in $bases; do args+=(-name $f -o); done
  args=($args[1,-2])
  files+=(${(f)"$(command find . -maxdepth 4 \
    \( -name node_modules -o -name .git \) -prune -o \
    -type f \( $args \) -print 2>/dev/null)"})
  (( $#files )) || return 0
  local n
  for n in ${(f)"$(command sed -nE \
      's/^[[:space:]]*(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*=.*/\2/p' \
      $files 2>/dev/null)"}; do
    _skip[$n]=1
  done
}

if [[ $mode == project ]]; then
  top=$(command git rev-parse --show-toplevel 2>/dev/null)
  if [[ -n $top ]]; then
    source "$HOME/.config/zsh/functions/secret.zsh" 2>/dev/null
    if (( $+functions[secret] && $+functions[_secret_resolve_project] )); then
      proj=$(_secret_resolve_project "")
      if [[ ${_SECRET_SHIM_PROJ:-} != "$proj" ]]; then
        _scan_dotenv "$top"
        _inject
        export _SECRET_SHIM_PROJ=$proj
      fi
    fi
  fi
else
  source "$HOME/.config/zsh/functions/secret.zsh" 2>/dev/null
  if (( $+functions[secret] )) && [[ ${_SECRET_SHIM_TOOL:-} != "$name" ]]; then
    _inject -p "$base"
    [[ $name != "$base" ]] && _inject -p "$name"
    export _SECRET_SHIM_TOOL=$name
  fi
fi

# Resolve the real binary from PATH, skipping this shim and its sibling
# symlinks by comparing resolved paths.
real=""
for c in ${(f)"$(whence -ap "$name")"}; do
  [[ ${c:A} == "$self" ]] && continue
  real=$c
  break
done
if [[ -z $real ]]; then
  print -ru2 -- "secret-shim: real '$name' not found in PATH"
  exit 127
fi
exec "$real" "$@"

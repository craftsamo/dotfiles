#!/usr/bin/env zsh
# secret-shim — thin launcher that injects Keychain secrets, then execs the
# real command.
#
# Usage: symlink a command name to this file:
#   ln -s secret-shim ~/.config/bin/<command>
# With this directory first in PATH, launching <command> injects
#   secret env -p global      layer shared by every tool
#   secret env -p <command>   tool-specific layer (overrides global)
# and then execs the real <command>. Inside a git repository secret.zsh's
# ambient scope applies on top, so per-repository overrides
# (secret set NAME -p <command> --scope <repo>) work as well.
#
# If the keychain cannot be unlocked, injection is skipped and the command
# starts anyway — the shim never blocks a launch.

emulate zsh

name=${0:t}
self=${0:A}

source "$HOME/.config/zsh/functions/secret.zsh" 2>/dev/null
if (( $+functions[secret] )); then
  eval "$(secret env -p global 2>/dev/null)"
  [[ $name != global ]] && eval "$(secret env -p "$name" 2>/dev/null)"
fi

# Resolve the real binary from PATH, skipping this shim and its sibling
# symlinks by comparing resolved paths.
real=""
for c in ${(f)"$(whence -ap "$name")"}; do
  [[ ${c:A} == "$self" ]] && continue
  real=$c
  break
done
if [[ -z $real ]]; then
  print -ru2 -- "secret-shim: real '$name' not found in PATH"
  exit 127
fi
exec "$real" "$@"

{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-claude-auth@latest",
    "@slkiser/opencode-quota"
  ],
  "instructions": [
    "instructions/*.txt"
  ],
  "agent": {
    "build": {
      "enable1mContext": true,
    },
    "plan": {
      "enable1mContext": true,
    },
    "explore": {
      "hidden": true,
    },
    "general": {
      "hidden": true,
    },
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "sudo *": "deny",
      "wget *": "deny",
      "dd *": "deny",
      ":(){ :|:& }; *": "deny",
      "ls*": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "du *": "allow",
      "df*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "jq *": "allow",
      "pwd*": "allow",
      "which *": "allow",
      "whoami*": "allow",
      "uname*": "allow",
      "date*": "allow",
      "git add *": "allow",
      "git diff*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git blame *": "allow",
      "git grep *": "allow",
      "git ls-files*": "allow",
      "git branch": "allow",
      "agent-browser *": "allow",
    },
    "skill": {
      "*": "ask",
    },
  },
}
